# --- WDK world (Postgres) ---
# Local Docker compose default:
WORKFLOW_TARGET_WORLD=@workflow/world-postgres
WORKFLOW_POSTGRES_URL=postgres://workflow:workflow@localhost:5440/workflow

# --- App's own Postgres (chat history). Reuse the same DB for the POC. ---
DATABASE_URL=postgres://workflow:workflow@localhost:5440/workflow

# --- AI provider ---
# Vercel AI Gateway key — the workflow uses gateway("deepseek/deepseek-v4-pro")
# (a reasoning/"thinking" model). One gateway key reaches any model.
AI_GATEWAY_API_KEY=vck_...
